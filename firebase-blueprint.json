{
  "entities": {
    "GlobalSettings": {
      "title": "Global Settings",
      "description": "General site configuration",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "lineId": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "aboutText": { "type": "string" }
      }
    },
    "HeroSettings": {
      "title": "Hero Settings",
      "description": "Content for the home page hero section",
      "type": "object",
      "properties": {
        "title_en": { "type": "string" },
        "title_th": { "type": "string" },
        "subtitle_en": { "type": "string" },
        "subtitle_th": { "type": "string" },
        "backgroundId": { "type": "string" }
      }
    },
    "StatsSettings": {
      "title": "Stats Settings",
      "description": "Company statistics displayed on the home page",
      "type": "object",
      "properties": {
        "yearsExp": { "type": "number" },
        "projects": { "type": "number" },
        "satisfaction": { "type": "number" },
        "support": { "type": "string" }
      }
    },
    "AdminUser": {
      "title": "Admin User",
      "description": "Authorized admin users",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Service": {
      "title": "Service",
      "description": "A service offered by the company",
      "type": "object",
      "properties": {
        "title_en": { "type": "string" },
        "title_th": { "type": "string" },
        "description_en": { "type": "string" },
        "description_th": { "type": "string" },
        "category_en": { "type": "string" },
        "category_th": { "type": "string" },
        "iconName": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "An item in the project gallery",
      "type": "object",
      "properties": {
        "title_en": { "type": "string" },
        "title_th": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "WhyUsFeature": {
      "title": "Why Us Feature",
      "description": "A feature explaining why to choose the company",
      "type": "object",
      "properties": {
        "title_en": { "type": "string" },
        "title_th": { "type": "string" },
        "description_en": { "type": "string" },
        "description_th": { "type": "string" },
        "iconName": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "FAQ": {
      "title": "FAQ",
      "description": "Frequently Asked Question",
      "type": "object",
      "properties": {
        "question_en": { "type": "string" },
        "question_th": { "type": "string" },
        "answer_en": { "type": "string" },
        "answer_th": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Customer review or testimonial",
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "role": { "type": "string" },
        "content": { "type": "string" },
        "rating": { "type": "number" },
        "order": { "type": "number" }
      }
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Customer contact request",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "read", "resolved"] },
        "createdAt": { "type": "string" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "A client project",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "progress": { "type": "number" },
        "status": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "projectUrl": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "ProjectFile": {
      "title": "Project File",
      "description": "A file or link associated with a project",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "fileData": { "type": "string" },
        "fileUrl": { "type": "string" },
        "isExternalLink": { "type": "boolean" },
        "uploadedAt": { "type": "string" }
      }
    },
    "LoginLog": {
      "title": "Login Log",
      "description": "A record of an admin login event",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "timestamp": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "userAgent": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/settings/global": { "schema": { "$ref": "#/entities/GlobalSettings" }, "description": "Global site settings" },
    "/settings/hero": { "schema": { "$ref": "#/entities/HeroSettings" }, "description": "Hero section content" },
    "/settings/stats": { "schema": { "$ref": "#/entities/StatsSettings" }, "description": "Company statistics" },
    "/admins/{adminId}": { "schema": { "$ref": "#/entities/AdminUser" }, "description": "Authorized admin users" },
    "/services/{serviceId}": { "schema": { "$ref": "#/entities/Service" }, "description": "List of services" },
    "/gallery/{itemId}": { "schema": { "$ref": "#/entities/GalleryItem" }, "description": "Project gallery items" },
    "/why_us/{featureId}": { "schema": { "$ref": "#/entities/WhyUsFeature" }, "description": "Why choose us features" },
    "/faqs/{faqId}": { "schema": { "$ref": "#/entities/FAQ" }, "description": "Frequently asked questions" },
    "/testimonials/{testimonialId}": { "schema": { "$ref": "#/entities/Testimonial" }, "description": "Customer testimonials" },
    "/inquiries/{inquiryId}": { "schema": { "$ref": "#/entities/Inquiry" }, "description": "Customer inquiries" },
    "/projects/{projectId}": { "schema": { "$ref": "#/entities/Project" }, "description": "Client projects" },
    "/project_files/{fileId}": { "schema": { "$ref": "#/entities/ProjectFile" }, "description": "Files for client projects" },
    "/login_logs/{logId}": { "schema": { "$ref": "#/entities/LoginLog" }, "description": "Admin login history" }
  }
}
