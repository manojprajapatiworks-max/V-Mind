{
  "entities": {
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global settings and content for the website",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string", "description": "Main heading on the home page" },
        "heroSubtitle": { "type": "string", "description": "Subheading on the home page" },
        "phoneNumber": { "type": "string", "description": "Contact phone number" },
        "lineId": { "type": "string", "description": "LINE App ID or URL" },
        "email": { "type": "string", "description": "Contact email address" },
        "address": { "type": "string", "description": "Physical address" },
        "aboutText": { "type": "string", "description": "About us description" }
      },
      "required": ["heroTitle", "heroSubtitle", "phoneNumber", "lineId", "email"]
    },
    "Service": {
      "title": "Service",
      "description": "A service offered by the company",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Name of the service" },
        "description": { "type": "string", "description": "Detailed description of the service" },
        "category": { "type": "string", "description": "Category (e.g., Electrical, Security, Networking)" },
        "iconName": { "type": "string", "description": "Lucide icon name" },
        "order": { "type": "number", "description": "Display order" }
      },
      "required": ["title", "description", "category", "iconName"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Customer contact request",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer name" },
        "email": { "type": "string", "description": "Customer email" },
        "phone": { "type": "string", "description": "Customer phone" },
        "message": { "type": "string", "description": "Inquiry message" },
        "status": { "type": "string", "enum": ["new", "read", "resolved"], "description": "Status of the inquiry" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "message", "status", "createdAt"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Customer review or testimonial",
      "type": "object",
      "properties": {
        "author": { "type": "string", "description": "Name of the customer" },
        "role": { "type": "string", "description": "Role or company of the customer" },
        "content": { "type": "string", "description": "Testimonial text" },
        "rating": { "type": "number", "description": "Rating out of 5" },
        "order": { "type": "number", "description": "Display order" }
      },
      "required": ["author", "content", "rating"]
    },
    "FAQ": {
      "title": "FAQ",
      "description": "Frequently Asked Question",
      "type": "object",
      "properties": {
        "question": { "type": "string", "description": "The question" },
        "answer": { "type": "string", "description": "The answer" },
        "order": { "type": "number", "description": "Display order" }
      },
      "required": ["question", "answer"]
    }
  },
  "firestore": {
    "/settings/global": {
      "schema": { "$ref": "#/entities/SiteSettings" },
      "description": "Singleton document for global site settings"
    },
    "/services/{serviceId}": {
      "schema": { "$ref": "#/entities/Service" },
      "description": "Collection of services"
    },
    "/inquiries/{inquiryId}": {
      "schema": { "$ref": "#/entities/Inquiry" },
      "description": "Collection of customer inquiries"
    },
    "/testimonials/{testimonialId}": {
      "schema": { "$ref": "#/entities/Testimonial" },
      "description": "Collection of customer testimonials"
    },
    "/faqs/{faqId}": {
      "schema": { "$ref": "#/entities/FAQ" },
      "description": "Collection of frequently asked questions"
    }
  }
}
