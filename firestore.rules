rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email != null && (
        request.auth.token.email.lower() == "manojprajapatiworks@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower()))
      );
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidGlobalSettings(data) {
      return hasOnlyAllowedFields(['companyName', 'logoUrl', 'phoneNumber', 'lineId', 'email', 'address', 'aboutText']) &&
             (!('companyName' in data) || (data.companyName is string && data.companyName.size() <= 200)) &&
             (!('logoUrl' in data) || (data.logoUrl is string && data.logoUrl.size() <= 500)) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 50)) &&
             (!('lineId' in data) || (data.lineId is string && data.lineId.size() <= 100)) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 100)) &&
             (!('address' in data) || (data.address is string && data.address.size() <= 500)) &&
             (!('aboutText' in data) || (data.aboutText is string && data.aboutText.size() <= 5000));
    }

    function isValidHeroSettings(data) {
      return hasOnlyAllowedFields(['title_en', 'title_th', 'subtitle_en', 'subtitle_th', 'backgroundId']) &&
             (!('title_en' in data) || (data.title_en is string && data.title_en.size() <= 200)) &&
             (!('title_th' in data) || (data.title_th is string && data.title_th.size() <= 200)) &&
             (!('subtitle_en' in data) || (data.subtitle_en is string && data.subtitle_en.size() <= 500)) &&
             (!('subtitle_th' in data) || (data.subtitle_th is string && data.subtitle_th.size() <= 500)) &&
             (!('backgroundId' in data) || (data.backgroundId is string && data.backgroundId.size() <= 100));
    }

    function isValidStatsSettings(data) {
      return hasOnlyAllowedFields(['yearsExp', 'projects', 'satisfaction', 'support']) &&
             (!('yearsExp' in data) || data.yearsExp is number) &&
             (!('projects' in data) || data.projects is number) &&
             (!('satisfaction' in data) || data.satisfaction is number) &&
             (!('support' in data) || (data.support is string && data.support.size() <= 100));
    }

    function isValidAdminUser(data) {
      return hasOnlyAllowedFields(['email', 'role', 'createdAt']) &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'superadmin'] &&
             (!('createdAt' in data) || data.createdAt is string);
    }
    
    function isValidService(data) {
      return hasOnlyAllowedFields(['title_en', 'title_th', 'description_en', 'description_th', 'category_en', 'category_th', 'iconName', 'order']) &&
             (!('title_en' in data) || (data.title_en is string && data.title_en.size() <= 200)) &&
             (!('title_th' in data) || (data.title_th is string && data.title_th.size() <= 200)) &&
             (!('description_en' in data) || (data.description_en is string && data.description_en.size() <= 2000)) &&
             (!('description_th' in data) || (data.description_th is string && data.description_th.size() <= 2000)) &&
             (!('category_en' in data) || (data.category_en is string && data.category_en.size() <= 100)) &&
             (!('category_th' in data) || (data.category_th is string && data.category_th.size() <= 100)) &&
             (!('iconName' in data) || (data.iconName is string && data.iconName.size() <= 100)) &&
             (!('order' in data) || data.order is number);
    }

    function isValidGalleryItem(data) {
      return hasOnlyAllowedFields(['title_en', 'title_th', 'imageUrl', 'category', 'order']) &&
             (!('title_en' in data) || (data.title_en is string && data.title_en.size() <= 200)) &&
             (!('title_th' in data) || (data.title_th is string && data.title_th.size() <= 200)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 500)) &&
             (!('category' in data) || (data.category is string && data.category.size() <= 100)) &&
             (!('order' in data) || data.order is number);
    }

    function isValidWhyUsFeature(data) {
      return hasOnlyAllowedFields(['title_en', 'title_th', 'description_en', 'description_th', 'iconName', 'order']) &&
             (!('title_en' in data) || (data.title_en is string && data.title_en.size() <= 200)) &&
             (!('title_th' in data) || (data.title_th is string && data.title_th.size() <= 200)) &&
             (!('description_en' in data) || (data.description_en is string && data.description_en.size() <= 1000)) &&
             (!('description_th' in data) || (data.description_th is string && data.description_th.size() <= 1000)) &&
             (!('iconName' in data) || (data.iconName is string && data.iconName.size() <= 100)) &&
             (!('order' in data) || data.order is number);
    }
    
    function isValidInquiry(data) {
      return hasOnlyAllowedFields(['name', 'email', 'phone', 'message', 'status', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 5000 &&
             data.status in ['new', 'read', 'resolved'] &&
             data.createdAt is string;
    }

    function isValidFAQ(data) {
      return hasOnlyAllowedFields(['question_en', 'question_th', 'answer_en', 'answer_th', 'order']) &&
             (!('question_en' in data) || (data.question_en is string && data.question_en.size() <= 500)) &&
             (!('question_th' in data) || (data.question_th is string && data.question_th.size() <= 500)) &&
             (!('answer_en' in data) || (data.answer_en is string && data.answer_en.size() <= 2000)) &&
             (!('answer_th' in data) || (data.answer_th is string && data.answer_th.size() <= 2000)) &&
             (!('order' in data) || data.order is number);
    }

    function isValidTestimonial(data) {
      return hasOnlyAllowedFields(['author', 'role', 'content', 'rating', 'order']) &&
             (!('author' in data) || (data.author is string && data.author.size() <= 100)) &&
             (!('role' in data) || (data.role is string && data.role.size() <= 100)) &&
             (!('content' in data) || (data.content is string && data.content.size() <= 1000)) &&
             (!('rating' in data) || data.rating is number) &&
             (!('order' in data) || data.order is number);
    }

    function isValidProject(data) {
      return hasOnlyAllowedFields(['customerId', 'title', 'description', 'progress', 'status', 'paymentStatus', 'projectUrl', 'createdAt', 'updatedAt']) &&
             data.customerId is string && data.customerId.size() > 0 &&
             data.title is string && data.title.size() > 0 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 5000)) &&
             data.progress is number && data.progress >= 0 && data.progress <= 100 &&
             (!('status' in data) || (data.status is string && data.status.size() <= 100)) &&
             (!('paymentStatus' in data) || (data.paymentStatus is string && data.paymentStatus.size() <= 100)) &&
             (!('projectUrl' in data) || (data.projectUrl is string && data.projectUrl.size() <= 2000)) &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidProjectFile(data) {
      return hasOnlyAllowedFields(['projectId', 'fileName', 'fileType', 'fileData', 'fileUrl', 'isExternalLink', 'uploadedAt']) &&
             data.projectId is string && data.projectId.size() > 0 &&
             data.fileName is string && data.fileName.size() > 0 &&
             (!('fileData' in data) || (data.fileData is string && data.fileData.size() <= 1048576)) &&
             (!('fileUrl' in data) || (data.fileUrl is string && data.fileUrl.size() <= 2000)) &&
             (!('isExternalLink' in data) || data.isExternalLink is bool) &&
             data.uploadedAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Settings (Public Read, Admin Write)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Services (Public Read, Admin Write)
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Gallery (Public Read, Admin Write)
    match /gallery/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Why Us (Public Read, Admin Write)
    match /why_us/{featureId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // FAQs (Public Read, Admin Write)
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Testimonials (Public Read, Admin Write)
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Inquiries (Public Create, Admin Read/Update/Delete)
    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(request.resource.data) && request.resource.data.status == 'new';
      allow read, update, delete: if isAdmin();
    }

    // Projects (Public Read, Admin Write)
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Project Files (Public Read, Admin Write)
    match /project_files/{fileId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admins (Admin Read/Write)
    match /admins/{adminEmail} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && isValidAdminUser(request.resource.data) && adminEmail.lower() == request.resource.data.email.lower();
      allow delete: if isAdmin();
    }
  }
}
